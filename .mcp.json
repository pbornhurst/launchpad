{
  "mcpServers": {
    "ask-data-ai": {
      "type": "http",
      "url": "https://cybertron-service-gateway-mcp.doordash.team/ask-data-ai/mcp"
    },
    "google-workspace": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "workspace-mcp"
      ],
      "env": {}
    },
    "intercom": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.intercom.com/mcp"
      ],
      "env": {}
    }
  }
}